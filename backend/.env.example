# Structured metadata database
DATABASE_URL=postgresql://visual_rag:visual_rag_password@localhost:55432/visual_rag

# Vector database. Use QDRANT_URL for production/maintainer handoff.
QDRANT_URL=http://localhost:6333
# QDRANT_PATH=./qdrant_data  # Local file-mode fallback only; do not use with QDRANT_URL in production.

# Embeddings. Ollama must be running and must have this model pulled.
OLLAMA_URL=http://localhost:11434
EMBED_MODEL=nomic-embed-text

# Answer generation and knowledge extraction.
# LLM_PROVIDER supports openai, anthropic, or ollama.
LLM_PROVIDER=openai
ANTHROPIC_API_KEY=<your-anthropic-key>
ANTHROPIC_MODEL=claude-sonnet-4-5
OPENAI_API_KEY=<your-openai-key>
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT=120
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT=120

# PDF parsing and VLM page understanding.
PDF_LOADER=pymupdf4llm
VLM_PROVIDER=anthropic
# VLM_PROVIDER=openai
ANTHROPIC_VISION_MODEL=claude-sonnet-4-5
OPENAI_VISION_MODEL=gpt-4.1-mini
VLM_RENDER_DPI=160
VLM_MAX_PAGES=20
VLM_MAX_TOKENS=1400
VLM_TIMEOUT=120
VLM_CONCURRENCY=4
VLM_CACHE=1
VLM_PAGE_TILES=1
VLM_TILE_GRID=2
VLM_SELECTION_MAX_TOKENS=700

# Knowledge node chunking and retrieval defaults.
CHUNK_SIZE=500
CHUNK_OVERLAP=50
CHUNK_MODE=semantic
SEMANTIC_THRESHOLD=0.70
TOP_K=5
MANUAL_BOOST=0.15

# Optional OCR fallback and knowledge graph extraction controls.
OCR_DPI=180
OCR_LANG=chi_tra+eng
KG_EXTRACTION_USE_LLM=1
KG_EXTRACTION_TIMEOUT=18
KG_EXTRACTION_CHAR_BUDGET=9000

# Optional external DSM image-recognition API.
DSM_API_BASE_URL=http://localhost:3000
EXTERNAL_VISION_API_URL=http://localhost:3000
DSM_API_TIMEOUT=8
